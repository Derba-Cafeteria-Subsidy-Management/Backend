generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CASHIER
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum MenuItemStatus {
  ACTIVE
  INACTIVE
}

enum AuditAction {
  USER_INVITED
  INVITATION_ACCEPTED
  LOGIN_SUCCESS
  LOGIN_FAILURE
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  LOGOUT
  LOGOUT_ALL
  USER_STATUS_CHANGED
  ROLE_CHANGED
  MENU_ITEM_CREATED
  MENU_ITEM_UPDATED
  MENU_ITEM_DELETED
  PRICE_HISTORY_CREATED
  create_transaction
  create_employee
  update_employee
  deactivate_employee
  activate_employee
  EMPLOYEE_DELETED
  create_correction_request
  approve_correction
  reject_correction
  create_subsidy_config
  offline_sync_batch
  SYSTEM_SETTINGS_UPDATED
}

enum FoodType {
  BREAKFAST
  LUNCH
  DINNER
  DRINK
}

model User {
  id              String     @id @default(uuid())
  Employee_number String?    @unique
  email           String     @unique
  passwordHash    String?
  role            UserRole
  status          UserStatus @default(PENDING)
  invitedById     String?
  invitedBy       User?      @relation("UserInvites", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers    User[]     @relation("UserInvites")
  lastLogin       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  refreshTokens              RefreshToken[]
  passwordResetTokens        PasswordResetToken[]
  invitationsSent            Invitation[]           @relation("InvitedBy")
  auditLogs                  AuditLog[]
  Transactions               Transaction[]
  correctionRequests         correction_requests[]  @relation("RequestedBy")
  approvedCorrectionRequests correction_requests[]  @relation("ApprovedCorrectionRequests")
  rejectedCorrectionRequests correction_requests[]  @relation("RejectedCorrectionRequests")
  offlineSyncRecords         offline_sync_records[]
  priceHistoryCreatedBy      price_history[]        @relation("PriceHistoryCreatedBy")
  systemSettings             system_settings[]

  @@index([role, status])
  @@map("users")
}

model Invitation {
  id          String    @id @default(uuid())
  email       String
  role        UserRole
  tokenHash   String    @unique
  expiresAt   DateTime
  invitedById String
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([email])
  @@map("invitations")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model menu_items {
  id   String @id @default(uuid())
  name String

  status MenuItemStatus @default(ACTIVE)

  mealtype FoodType

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  PriceHistory price_history[]
  transactions TransactionItem[]

  @@index([status])
  @@map("menu_items")
}

model price_history {
  id            String     @id @default(uuid())
  menuItemId    String
  menuItem      menu_items @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  price         Float
  effctive_from DateTime
  effective_to  DateTime?
  createdBy     String
  createdByUser User       @relation("PriceHistoryCreatedBy", fields: [createdBy], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([menuItemId, effctive_from])
  @@index([menuItemId, effective_to])
  @@map("price_history")
}

model Device {
  id String @id @default(cuid())

  code String @unique

  name String

  provider DeviceProvider

  ipAddress String?

  location String?

  status DeviceStatus

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  mappings BiometricMapping[]

  scanLogs ScanLog[]

  @@map("devices")
}

model BiometricMapping {
  id String @id @default(cuid())

  employeeId String

  deviceId String

  deviceUserId String

  employee employees @relation(fields: [employeeId], references: [id])

  device Device @relation(fields: [deviceId], references: [id])

  @@unique([deviceId, deviceUserId])
  @@map("biometric_mappings")
}

model ScanLog {
  id String @id @default(cuid())

  deviceId String

  employeeId String?

  verified Boolean

  payload Json?

  scannedAt DateTime

  device Device @relation(fields: [deviceId], references: [id])

  @@map("scan_logs")
}

enum DeviceProvider {
  MOCK

  ZKTECO

  SUPREMA
}

enum DeviceStatus {
  ONLINE

  OFFLINE

  DISABLED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum mealType {
  BREAKFAST
  LUNCH
  DINNER
}

enum SubsidyType {
  NORMAL
  SPECIAL
}

model employees {
  id              String         @id @default(uuid())
  Employee_number String         @unique
  photo           String?
  full_name       String
  fingerprint_id  String?        @unique
  status          EmployeeStatus @default(ACTIVE)
  created_at      DateTime       @default(now())
  subsidyType     SubsidyType    @default(NORMAL)

  updated_at              DateTime                  @updatedAt
  Transactions            Transaction[]
  biometricMappings       BiometricMapping[]
  employeeSessionStatuses employee_session_status[]

  @@index([status])
  @@index([full_name])
  @@index([subsidyType, Employee_number])
  @@index([subsidyType, full_name])
  @@map("employees")
}

model TransactionItem {
  id String @id

  transactionId String

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  menu_item_id String

  menu_item menu_items @relation(fields: [menu_item_id], references: [id], onDelete: Cascade)

  menu_price Float

  employee_share Float

  company_share Float

  quantity Int @default(1)

  createdAt DateTime @default(now())

  correction_requests correction_requests[]

  @@index([transactionId])
  @@map("transaction_items")
}

model Transaction {
  id String @id

  employeeId String

  employee employees @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  menu_session mealType

  transactionDate DateTime @db.Date

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  cashierId String

  cashier User @relation(fields: [cashierId], references: [id], onDelete: Cascade)

  items TransactionItem[]

  offline_sync_records offline_sync_records[]

  @@index([employeeId, menu_session, transactionDate])
  @@index([transactionDate])
  @@index([cashierId, transactionDate])
  @@index([employeeId, transactionDate])
  @@index([transactionDate, menu_session])
  @@map("transactions")
}

model employee_session_status {
  id String @id @default(cuid())

  employeeId String

  date DateTime

  session mealType

  mealConsumed Int @default(0)

  drinkConsumed Int @default(0)

  employee employees @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date, session])
}

model correction_requests {
  id                String                  @id
  transactionItemId String
  transactionItem   TransactionItem         @relation(fields: [transactionItemId], references: [id], onDelete: Cascade)
  requestedById     String
  requestedBy       User                    @relation("RequestedBy", fields: [requestedById], references: [id], onDelete: Cascade)
  reason            String
  status            CorrectionRequestStatus @default(PENDING)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  old_values Json?
  new_values Json?

  approvedById    String?
  approvedBy      User?     @relation("ApprovedCorrectionRequests", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt      DateTime?
  rejectedById    String?
  rejectedBy      User?     @relation("RejectedCorrectionRequests", fields: [rejectedById], references: [id], onDelete: SetNull)
  rejectedAt      DateTime?
  rejectionReason String?

  @@index([status])
  @@index([createdAt])
  @@index([status, transactionItemId])
  @@index([status, createdAt])
  @@map("correction_requests")
}

enum CorrectionRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Subsidy_config {
  id             String        @id @default(uuid())
  company_share  Float
  employee_share Float
  policy SubsidyPolicy @default(DEFAULT)
  effective_from DateTime
  effective_to   DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([effective_from])
  @@index([effective_to])
  @@map("subsidy_config")
}

enum SubsidyPolicy {
  DEFAULT
  FULL_COMPANY
}

model offline_sync_records {
  id            String       @id
  localId       String       @unique
  stationId     String
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  cashierId     String
  cashier       User         @relation(fields: [cashierId], references: [id], onDelete: Cascade)
  syncStatus    String
  syncReason    String?
  createdAt     DateTime     @default(now())

  @@index([stationId])
  @@index([cashierId])
  @@index([syncStatus])
  @@index([createdAt])
  @@map("offline_sync_records")
}

model system_settings {
  id String @id @default(uuid())

  fingerprintEnabled    Boolean @default(true)
  employeeSearchEnabled Boolean @default(true)

  updatedById String?
  updatedBy   User?   @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model AuditLog {
  id         String      @id
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
